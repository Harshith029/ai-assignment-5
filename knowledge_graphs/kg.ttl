@prefix ex: <http://example.org/india-kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Charminar a ex:Monument,
        ex:Place ;
    ex:builtBy ex:QuliQutbShah ;
    ex:locatedIn ex:Hyderabad .

ex:GatewayOfIndia a ex:Monument,
        ex:Place ;
    ex:builtBy ex:GeorgeWittet ;
    ex:locatedIn ex:Mumbai .

ex:GolcondaFort a ex:Monument,
        ex:Place ;
    ex:builtBy ex:IbrahimQuliQutbShah ;
    ex:locatedIn ex:Hyderabad .

ex:HawaMahal a ex:Monument,
        ex:Place ;
    ex:builtBy ex:SawaiPratapSingh ;
    ex:locatedIn ex:Jaipur .

ex:MysorePalace a ex:Monument,
        ex:Place ;
    ex:builtBy ex:KrishnarajaWadiyarIV ;
    ex:locatedIn ex:Mysore .

ex:QutbMinar a ex:Monument,
        ex:Place ;
    ex:builtBy ex:QutbuddinAibak ;
    ex:locatedIn ex:Delhi .

ex:RamojiFilmCity a ex:Monument,
        ex:Place ;
    ex:locatedIn ex:Hyderabad .

ex:RedFort a ex:Monument,
        ex:Place ;
    ex:builtBy ex:ShahJahan ;
    ex:locatedIn ex:Delhi .

ex:TajMahal a ex:Monument,
        ex:Place ;
    ex:builtBy ex:ShahJahan ;
    ex:locatedIn ex:Agra .

ex:builtBy rdfs:domain ex:Monument ;
    rdfs:range ex:Person .

ex:capitalOf rdfs:subPropertyOf ex:locatedIn .

ex:dynasty rdfs:domain ex:Person ;
    rdfs:range ex:Dynasty .

ex:Agra a ex:Place ;
    ex:locatedIn ex:UttarPradesh .

ex:GeorgeWittet a ex:Person .

ex:IbrahimQuliQutbShah a ex:Person ;
    ex:dynasty ex:QutbShahi .

ex:Jaipur a ex:Place ;
    ex:capitalOf ex:Rajasthan ;
    ex:locatedIn ex:Rajasthan .

ex:Kachwaha a ex:Dynasty .

ex:Karnataka a ex:Place ;
    ex:locatedIn ex:India .

ex:KrishnarajaWadiyarIV a ex:Person ;
    ex:dynasty ex:Wadiyar .

ex:Maharashtra a ex:Place ;
    ex:locatedIn ex:India .

ex:MamlukDelhi a ex:Dynasty .

ex:Mughal a ex:Dynasty .

ex:Mumbai a ex:Place ;
    ex:locatedIn ex:Maharashtra .

ex:Mysore a ex:Place ;
    ex:locatedIn ex:Karnataka .

ex:QuliQutbShah a ex:Person ;
    ex:dynasty ex:QutbShahi .

ex:QutbuddinAibak a ex:Person ;
    ex:dynasty ex:MamlukDelhi .

ex:SawaiPratapSingh a ex:Person ;
    ex:dynasty ex:Kachwaha .

ex:UttarPradesh a ex:Place ;
    ex:locatedIn ex:India .

ex:Wadiyar a ex:Dynasty .

ex:locatedIn a owl:TransitiveProperty .

ex:Delhi a ex:Place ;
    ex:locatedIn ex:India .

ex:QutbShahi a ex:Dynasty .

ex:Rajasthan a ex:Place ;
    ex:locatedIn ex:India .

ex:ShahJahan a ex:Person ;
    ex:dynasty ex:Mughal .

ex:Telangana a ex:Place ;
    ex:locatedIn ex:India .

ex:Hyderabad a ex:Place ;
    ex:capitalOf ex:Telangana ;
    ex:locatedIn ex:Telangana .

ex:Dynasty a owl:Class .

ex:India a ex:Place .

ex:Person a owl:Class .

ex:Monument a owl:Class .

ex:Place a owl:Class .

